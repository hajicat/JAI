# Environment Variables
# Copy this file to .env and fill in the values

# JWT Secret (auto-generated if not set, stored in data/.secrets.json)
JWT_SECRET=

# AES Encryption Key (auto-generated if not set, stored in data/.secrets.json)
ENCRYPT_SECRET=

# Turso Database (for production)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Node Environment
NODE_ENV=development
